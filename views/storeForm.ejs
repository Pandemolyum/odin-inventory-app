<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include("partials/header.ejs") %>

    <% 
        const isEdit = typeof store !== 'undefined' && store !== null;
        const actionUrl = isEdit ? `/stores/edit/${store.store_id}?_method=PUT` : '/stores/new';
        const pageTitle = isEdit ? 'Edit Store Details' : 'Add a New Store';
        const buttonText = isEdit ? 'Save Changes' : 'Create Store';
    %>

    <main class="main-form-content">
        <div class="form-card">
            <div class="form-header">
                <h2><%= pageTitle %></h2>
            </div>

            <form action="<%= actionUrl %>" method="POST">
                <div class="form-group">
                    <label for="store_name">Store Name *</label>
                    <input type="text" id="store_name" name="store_name" value="<%= isEdit ? store.store_name : '' %>"
                        required placeholder="e.g. Downtown Supermarket">
                </div>

                <div class="form-group">
                    <label for="store_brand">Brand</label>
                    <input type="text" id="store_brand" name="store_brand"
                        value="<%= isEdit ? store.store_brand : '' %>" placeholder="e.g. Costco">
                </div>

                <div class="form-group">
                    <label for="address">Street Address</label>
                    <input type="text" id="address" name="address" value="<%= isEdit ? store.address : '' %>"
                        placeholder="e.g. 123 Jean-Guy St">
                </div>

                <div class="form-group">
                    <label for="city">City</label>
                    <input type="text" id="city" name="city" value="<%= isEdit ? store.city : '' %>"
                        placeholder="e.g. Montreal">
                </div>

                <div class="form-group">
                    <label for="country">Country</label>
                    <input type="text" id="country" name="country" value="<%= isEdit ? store.country : '' %>"
                        placeholder="e.g. Canada">
                </div>

                <div class="form-actions">
                    <a href="/stores" class="btn btn-cancel">Cancel</a>
                    <button type="submit" class="btn btn-submit"><%= buttonText %></button>
                </div>
            </form>
            <%- include("partials/errors.ejs") %>
        </div>
    </main>
</body>

</html>